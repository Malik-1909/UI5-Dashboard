<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Bar>
        <contentLeft>
            <Button icon="sap-icon://nav-back" tooltip="{i18n>nav.back}" accessibleName="{i18n>nav.backAccessible}" press=".onNavBack"/>
            <Title text="{proc>/title}" level="H2"/>
        </contentLeft>
        <contentMiddle/>
        <contentRight>
            <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
            <Button id="burgerButton" icon="sap-icon://menu2" tooltip="{i18n>nav.menu}" accessibleName="{i18n>main.menuAccessible}" press=".onBurgerPress" class="headerBurgerButton"/>
        </contentRight>
    </Bar>
</core:FragmentDefinition>
