<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Popover
        id="chatPopover"
        title="{i18n>chat.assistant}"
        placement="Top"
        contentWidth="340px"
        contentHeight="420px"
        verticalScrolling="false"
        horizontalScrolling="false">

        <content>
            <VBox class="chatBody" fitContainer="true">
                <ScrollContainer
                    id="chatScroll"
                    height="100%"
                    vertical="true"
                    horizontal="false"
                    focusable="true"
                    class="chatScrollArea">
                    <VBox id="chatMessages" class="chatMessages" />
                </ScrollContainer>
            </VBox>
        </content>

        <footer>
            <VBox class="chatComposerOuter" width="100%">
                <HBox
                    class="chatComposer"
                    alignItems="Center"
                    justifyContent="Start"
                    width="100%">
                    <Input
                        id="chatInput"
                        class="chatComposerInput"
                        placeholder="{i18n>chat.placeholder}"
                        accessibleName="{i18n>chat.inputAccessible}">
                        <layoutData>
                            <FlexItemData growFactor="1" shrinkFactor="1" baseSize="0"/>
                        </layoutData>
                    </Input>
                    <Button
                        id="chatSendBtn"
                        class="chatComposerSendBtn"
                        icon="sap-icon://paper-plane"
                        type="Emphasized"
                        tooltip="{i18n>chat.send}"
                        accessibleName="{i18n>chat.sendAccessible}" />
                </HBox>
            </VBox>
        </footer>

    </Popover>

</core:FragmentDefinition>
