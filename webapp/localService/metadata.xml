      </EntityType>
      <EntityType Name="S2PInvoiceCycle">
        <Key><PropertyRef Name="month"/></Key>
        <Property Name="month" Type="Edm.String" Nullable="false"/>
        <Property Name="days" Type="Edm.Int32"/>
      </EntityType>
      <EntityType Name="S2PKpiTable">
        <Key><PropertyRef Name="kpi"/></Key>
        <Property Name="kpi" Type="Edm.String" Nullable="false"/>
        <Property Name="value" Type="Edm.String"/>
        <Property Name="unit" Type="Edm.String"/>
      </EntityType>
      <!-- D2O -->
      <EntityType Name="D2OProcessFunnel">
        <Key><PropertyRef Name="stage"/></Key>
        <Property Name="stage" Type="Edm.String" Nullable="false"/>
        <Property Name="count" Type="Edm.Int32"/>
      </EntityType>
      <EntityType Name="D2OCapacityUtil">
        <Key><PropertyRef Name="workcenter"/></Key>
        <Property Name="workcenter" Type="Edm.String" Nullable="false"/>
