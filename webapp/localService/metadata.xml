      </EntityType>
      <EntityType Name="CustomerSegments">
        <Key><PropertyRef Name="segment"/></Key>
        <Property Name="segment" Type="Edm.String" Nullable="false"/>
        <Property Name="revenue" Type="Edm.Int32"/>
        <Property Name="customers" Type="Edm.Int32"/>
      </EntityType>
