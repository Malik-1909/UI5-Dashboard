      <!-- R2R -->
      <EntityType Name="R2RByAccountType">
        <Key><PropertyRef Name="type"/></Key>
        <Property Name="type" Type="Edm.String" Nullable="false"/>
        <Property Name="share" Type="Edm.Int32"/>
      </EntityType>
      <EntityType Name="R2RKpiTable">
        <Key><PropertyRef Name="kpi"/></Key>
        <Property Name="kpi" Type="Edm.String" Nullable="false"/>
        <Property Name="value" Type="Edm.String"/>
        <Property Name="unit" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="R2RJournalEntries">
        <Key><PropertyRef Name="period"/></Key>
        <Property Name="period" Type="Edm.String" Nullable="false"/>
        <Property Name="entries" Type="Edm.Int32"/>
      </EntityType>
      <EntityType Name="R2RCloseCycle">
        <Key><PropertyRef Name="month"/></Key>
        <Property Name="month" Type="Edm.String" Nullable="false"/>
