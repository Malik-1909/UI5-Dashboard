        <EntitySet Name="MonthlyRevenue" EntityType="KPI.MonthlyRevenue"/>
        <EntitySet Name="RegionRevenue" EntityType="KPI.RegionRevenue"/>
        <EntitySet Name="ProductShare" EntityType="KPI.ProductShare"/>
        <EntitySet Name="QuarterlyProfit" EntityType="KPI.QuarterlyProfit"/>
        <EntitySet Name="EmployeeSatisfaction" EntityType="KPI.EmployeeSatisfaction"/>
        <EntitySet Name="TicketVolume" EntityType="KPI.TicketVolume"/>
        <EntitySet Name="BudgetAllocation" EntityType="KPI.BudgetAllocation"/>
        <EntitySet Name="ConversionFunnel" EntityType="KPI.ConversionFunnel"/>
        <EntitySet Name="WeeklyOrders" EntityType="KPI.WeeklyOrders"/>
        <EntitySet Name="CustomerSegments" EntityType="KPI.CustomerSegments"/>
      </EntityContainer>
