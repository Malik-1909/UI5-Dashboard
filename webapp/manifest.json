{
  "_version": "1.59.0",
  "sap.app": {
    "id": "ui5.vizframe.app",
    "type": "application",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "UI5 VizFrame App",
    "description": "SAPUI5 App mit VizFrame Charts"
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.130.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.viz": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
"models": {},
    "rootView": {
      "viewName": "ui5.vizframe.app.view.App",
      "type": "XML",
      "async": true,
      "id": "appView"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "ui5.vizframe.app.view",
        "controlAggregation": "pages",
        "controlId": "app"
      },
      "routes": [
        {
          "name": "main",
          "pattern": "",
          "target": ["main"]
        },
        {
          "name": "project",
          "pattern": "project",
          "target": ["project"]
        },
        {
          "name": "r2r",
          "pattern": "r2r",
          "target": ["r2r"]
        },
        {
          "name": "rtr",
          "pattern": "rtr",
          "target": ["rtr"]
        },
        {
          "name": "s2p",
          "pattern": "s2p",
          "target": ["s2p"]
        },
        {
          "name": "d2o",
          "pattern": "d2o",
          "target": ["d2o"]
        },
        {
          "name": "l2c",
          "pattern": "l2c",
          "target": ["l2c"]
        }
      ],
      "targets": {
        "main": {
          "viewType": "XML",
          "viewId": "mainView",
          "viewName": "Main"
        },
        "project": {
          "viewType": "XML",
          "viewId": "projectView",
          "viewName": "Project"
        },
        "r2r": {
          "viewType": "XML",
          "viewId": "r2rView",
          "viewName": "R2R"
        },
        "rtr": {
          "viewType": "XML",
          "viewId": "rtrView",
          "viewName": "RtR"
        },
        "s2p": {
          "viewType": "XML",
          "viewId": "s2pView",
          "viewName": "S2P"
        },
        "d2o": {
          "viewType": "XML",
          "viewId": "d2oView",
          "viewName": "D2O"
        },
        "l2c": {
          "viewType": "XML",
          "viewId": "l2cView",
          "viewName": "L2C"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    }
  }
}
