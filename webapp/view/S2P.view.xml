<mvc:View
    controllerName="ui5.vizframe.app.controller.S2P"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="s2pPage" title="Source to Pay" enableScrolling="true" showHeader="true">
        <customHeader>
            <core:Fragment fragmentName="ui5.vizframe.app.fragment.ProcessDetailHeader" type="XML"/>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <Title text="Source to Pay Prozess" level="H3"/>
                    <Text text="Source to Pay (S2P) beschreibt den Beschaffungsprozess von der Bedarfsmeldung bis zur Zahlung an den Lieferanten. Der Prozess verbindet Einkauf, Logistik und Finanzen."
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="{sales>/_sapBadgeS2P}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeS2P}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="Demo-Daten (Mock) · SAP API nicht konfiguriert oder nicht erreichbar"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeS2P}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="KPI-Übersicht" level="H4"/>
                            <Table id="s2pKpiTable" items="{sales>/S2PKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="KPI"/></Column>
                                    <Column><Text text="Wert"/></Column>
                                    <Column><Text text="Einheit"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="Wichtige Diagramme für S2P" level="H3" class="sapUiSmallMarginTop"/>
                    <Text text="Die folgenden Diagramme unterstützen die Steuerung des Beschaffungsprozesses: Durchlaufmengen, Ausgaben nach Kategorie und Zahlungszyklus."
                        class="sapUiSmallMarginBottom"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. S2P-Prozess-Funnel' + (${sales>/_sapBadgeS2P} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <Text text="Zeigt die Anzahl Bestellvorgänge pro Stufe. Wichtig zur Identifikation von Engpässen (z.B. viele offene Rechnungsprüfungen)."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="s2pFunnelChart"
                                vizType="bar"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Bestellvorgänge pro Prozessstufe' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/S2PProcessFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Bestellungen je Einkaufsorganisation' + (${sales>/_sapBadgeS2P} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <Text text="Verteilung der Bestellbelege je Einkaufsorganisation (Anzahl). Im API-Header stehen keine Nettobeträge – daher Beleganzahl statt EUR."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="s2pSpendChart"
                                vizType="donut"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Beleganteil je Organisation (%)' },
                                    plotArea: { dataLabel: { visible: true, type: 'percentage' }, colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E'] },
                                    legend: { visible: true }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/S2PSpendByCategory}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Kategorie" value="{sales>category}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anteil" value="{sales>amount}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Anteil"/>
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Kategorie"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Bestelleingang pro Monat' + (${sales>/_sapBadgeS2P} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <Text text="Zeigt die monatliche Entwicklung des Bestelleingangs. Wichtig für Einkaufsplanung, Lieferantensteuerung und Saisonalitätsanalyse."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="s2pOrdersTrendChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Bestelleingang pro Monat' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/S2POrdersByMonth}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Bestellungen" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Bestellungen"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Title text="Zusammenfassung" level="H4"/>
                    <Text text="Für S2P sind Säulendiagramme (Bestelltypen, Bestelleingang pro Monat), Donut (Ausgaben je Kategorie) und Kennzahlen-Tabelle relevant."
                        class="sapUiSmallMarginBottom"/>
                    <Panel expandable="true" expanded="false" width="100%" class="processDetailStepsPanel sapUiSmallMarginTop">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Prozessschritte" level="H4"/>
                                <ToolbarSpacer/>
                                <core:Icon src="sap-icon://message-information" tooltip="Nur Phasenüberblick; KPI und Diagramme sind für die Steuerung maßgeblich." decorative="false"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List class="processDetailStepsList">
                                <StandardListItem title="1. Bedarfsmeldung" info="Bedarfsanforderung wird erstellt und freigegeben"/>
                                <StandardListItem title="2. Bestellung" info="Bestellung beim Lieferanten wird ausgelöst"/>
                                <StandardListItem title="3. Wareneingang" info="Wareneingang und Prüfung"/>
                                <StandardListItem title="4. Rechnungsprüfung" info="Dreiseitenabgleich und Rechnungsfreigabe"/>
                                <StandardListItem title="5. Zahlung" info="Zahlungsabwicklung an den Lieferanten"/>
                            </List>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
