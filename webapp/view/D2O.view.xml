<mvc:View
    controllerName="ui5.vizframe.app.controller.D2O"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="d2oPage" title="Design to Operate" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" tooltip="Zurück" accessibleName="Zurück zur Startseite" press=".onNavBack"/>
                    <Title text="Design to Operate" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="Menü" accessibleName="Hauptmenü öffnen" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <Title text="Design to Operate Prozess" level="H3"/>
                    <Text text="Design to Operate (D2O) beschreibt den Prozess von der Produktentwicklung bis zum Betrieb und Service. Der Prozess verbindet Design, Engineering, Fertigung und Service."
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="{sales>/_sapBadgeD2O}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeD2O}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="Demo-Daten (Mock) · SAP API nicht erreichbar"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeD2O}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="KPI-Übersicht" level="H4"/>
                            <Table id="d2oKpiTable" items="{sales>/D2OKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="KPI"/></Column>
                                    <Column><Text text="Wert"/></Column>
                                    <Column><Text text="Einheit"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="Wichtige Diagramme für D2O" level="H3" class="sapUiSmallMarginTop"/>
                    <Text text="Die folgenden Diagramme basieren auf Warenbewegungen und Lagerbeständen (Design-to-Operate als Supply-Chain-Sicht)."
                        class="sapUiSmallMarginBottom"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. D2O-Prozess-Funnel' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <Text text="Warenbewegungen nach Bewegungsart (InventoryTransactionType / Warenbewegungscode). Zeigt das logistische Volumen im System."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="d2oFunnelChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Warenbewegungen nach Art' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OProcessFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Lager nach Werk (relativ)' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <Text text="Vergleicht die relative Lagermenge je Werk (normalisiert auf das größte Werk). Zielwert 85 % dient als Referenz."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="d2oCapacityChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Lagermenge je Werk (Ist vs. Ziel %)' },
                                    plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2','#F58B00'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OCapacityUtil}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Bereich" value="{sales>workcenter}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Ist" value="{sales>util}"/>
                                            <viz.data:MeasureDefinition name="Ziel" value="{sales>target}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Ist,Ziel"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Bereich"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Warenbewegungen pro Monat' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <Text text="Zeigt die Anzahl Warenbewegungsbelege je Monat (Posting-Datum)."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="d2oOutputChart"
                                vizType="line"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Warenbewegungen (Anzahl)' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#107E3E'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OOutputTrend}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Belege" value="{sales>output}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Belege"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Title text="Zusammenfassung" level="H4"/>
                    <Text text="D2O nutzt hier Warenbewegungen und Lagerdaten aus der SAP Sandbox (keine Produktionsaufträge wegen API-Berechtigung)."
                        class="sapUiSmallMarginBottom"/>
                    <Panel expandable="true" expanded="false" width="100%" class="processDetailStepsPanel sapUiSmallMarginTop">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Prozessschritte" level="H4"/>
                                <ToolbarSpacer/>
                                <core:Icon src="sap-icon://message-information" tooltip="Nur Phasenüberblick; KPI und Diagramme sind für die Steuerung maßgeblich." decorative="false"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List class="processDetailStepsList">
                                <StandardListItem title="1. Design" info="Produktdesign und Konzeptentwicklung"/>
                                <StandardListItem title="2. Engineering" info="Konstruktion und technische Spezifikation"/>
                                <StandardListItem title="3. Procure" info="Beschaffung von Komponenten"/>
                                <StandardListItem title="4. Manufacture" info="Fertigung und Montage"/>
                                <StandardListItem title="5. Deploy" info="Auslieferung und Installation"/>
                                <StandardListItem title="6. Operate" info="Betrieb und Wartung"/>
                                <StandardListItem title="7. Service" info="Reparatur und Support"/>
                            </List>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
