<mvc:View
    controllerName="ui5.vizframe.app.controller.D2O"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="d2oPage" title="{i18n>process.d2o}" enableScrolling="true" showHeader="true">
        <customHeader>
            <core:Fragment fragmentName="ui5.vizframe.app.fragment.ProcessDetailHeader" type="XML"/>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <MessageStrip
                        text="{sales>/_sapBadgeD2O}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeD2O}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="{i18n>detail.mockWarning}"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeD2O}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="{i18n>detail.kpiOverview}" level="H4"/>
                            <Table id="d2oKpiTable" items="{sales>/D2OKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="{i18n>detail.colKpi}"/></Column>
                                    <Column><Text text="{i18n>detail.colValue}"/></Column>
                                    <Column><Text text="{i18n>detail.colUnit}"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="{i18n>detail.charts}" level="H3" class="sapUiSmallMarginTop"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. D2O-Prozess-Funnel' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="d2oFunnelChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Warenbewegungen nach Art' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OProcessFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Lager nach Werk (relativ)' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="d2oCapacityChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Lagermenge je Werk (Ist vs. Ziel %)' },
                                    plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2','#F58B00'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OCapacityUtil}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Bereich" value="{sales>workcenter}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Ist" value="{sales>util}"/>
                                            <viz.data:MeasureDefinition name="Ziel" value="{sales>target}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Ist,Ziel"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Bereich"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Warenbewegungen pro Monat' + (${sales>/_sapBadgeD2O} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <viz:VizFrame
                                id="d2oOutputChart"
                                vizType="line"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Warenbewegungen (Anzahl)' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#107E3E'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/D2OOutputTrend}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Belege" value="{sales>output}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Belege"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
