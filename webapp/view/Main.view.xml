<mvc:View
    controllerName="ui5.vizframe.app.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="mainPage" title="{i18n>main.pageTitle}" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <core:Icon src="sap-icon://sap-logo" size="1.5rem" decorative="true"/>
                    <Title text="{i18n>main.headerTitle}" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="{i18n>main.menuTooltip}" accessibleName="{i18n>main.menuAccessible}" press=".onBurgerPress" class="headerBurgerButton"/>
                    <Button text="{i18n>main.aboutButton}" tooltip="{i18n>main.aboutTooltip}" accessibleName="{i18n>main.aboutAccessible}" press=".onNavToProject" class="headerDesktopActions"/>
                    <Button id="prozesseButton" text="{i18n>main.processButton}" tooltip="{i18n>main.processTooltip}" accessibleName="{i18n>main.processAccessible}" press=".onProzessePress" class="headerDesktopActions"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <MessageStrip
                id="btpHealthStrip"
                visible="{btpHealth>/visible}"
                text="{i18n>main.btpHealthOffline}"
                type="Warning"
                showIcon="true"
                showCloseButton="true"
                close=".onBtpHealthStripClose"
                link="{i18n>main.btpHealthLink}"
                linkPress=".onBtpHealthLinkPress"
                class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
            <cssgrid:CSSGrid
                id="processTilesGrid"
                gridTemplateColumns="1fr 1fr 1fr 1fr 1fr 1fr"
                gridGap="2rem"
                gridTemplateRows="auto auto"
                class="processTilesGrid">
                <!-- Zeile 1: 3 Kacheln (je 1/3) - RtR, R2R, S2P -->
                <!-- Recruit to Retire Tile -->
                <GenericTile
                    id="tileRtR"
                    header="{i18n>process.rtr}"
                    subheader="{i18n>tile.rtr.subheader}"
                    tooltip="{i18n>tile.rtr.tooltip}"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartRtR"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/RtrHeadcountFunnel}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="{i18n>chart.dim.stage}" value="{sales>stage}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="{i18n>chart.dim.count}" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="{i18n>chart.dim.count}"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="{i18n>chart.dim.stage}"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Record to Report Tile -->
                <GenericTile
                    id="tileR2R"
                    header="{i18n>process.r2r}"
                    subheader="{i18n>tile.r2r.subheader}"
                    tooltip="{i18n>tile.r2r.tooltip}"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartR2R"
                                    vizType="pie"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: {
                                            dataLabel: { visible: true, type: 'value' },
                                            colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E','#F58B00'],
                                            margin: { top: 8, right: 8, bottom: 4, left: 8 }
                                        },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/R2RByAccountType}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="{i18n>chart.dim.accountClass}" value="{sales>type}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="{i18n>chart.dim.sharePercent}" value="{sales>share}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="size" type="Measure" values="{i18n>chart.dim.sharePercent}"/>
                                        <viz.feeds:FeedItem uid="color" type="Dimension" values="{i18n>chart.dim.accountClass}"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Source to Pay Tile -->
                <GenericTile
                    id="tileS2P"
                    header="{i18n>process.s2p}"
                    subheader="{i18n>tile.s2p.subheader}"
                    tooltip="{i18n>tile.s2p.tooltip}"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartS2P"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: {
                                            dataLabel: { visible: true, type: 'value' },
                                            colorPalette: ['#0070F2'],
                                            margin: { top: 12, right: 8, bottom: 4, left: 44 }
                                        },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/S2POrdersByMonth}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="{i18n>chart.dim.month}" value="{sales>month}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="{i18n>chart.dim.orders}" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="{i18n>chart.dim.orders}"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="{i18n>chart.dim.month}"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Zeile 2: 2 Kacheln (je 50%) - D2O, L2C -->
                <!-- Design to Operate Tile -->
                <GenericTile
                    id="tileD2O"
                    header="{i18n>process.d2o}"
                    subheader="{i18n>tile.d2o.subheader}"
                    tooltip="{i18n>tile.d2o.tooltip}"
                    class="processTile tileHalf"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartD2O"
                                    vizType="line"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#107E3E'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/D2OOutputTrend}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="{i18n>chart.dim.month}" value="{sales>month}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="{i18n>chart.dim.output}" value="{sales>output}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="{i18n>chart.dim.output}"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="{i18n>chart.dim.month}"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Lead to Cash Tile -->
                <GenericTile
                    id="tileL2C"
                    header="{i18n>process.l2c}"
                    subheader="{i18n>tile.l2c.subheader}"
                    tooltip="{i18n>tile.l2c.tooltip}"
                    class="processTile tileHalf"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartL2C"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/L2CConversionFunnel}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="{i18n>chart.dim.stage}" value="{sales>stage}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="{i18n>chart.dim.count}" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="{i18n>chart.dim.count}"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="{i18n>chart.dim.stage}"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
            </cssgrid:CSSGrid>
        </content>
    </Page>
</mvc:View>
