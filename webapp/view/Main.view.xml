<mvc:View
    controllerName="ui5.vizframe.app.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="mainPage" title="{i18n>main.pageTitle}" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <core:Icon src="sap-icon://sap-logo" size="1.5rem" decorative="true"/>
                    <Title text="{i18n>main.headerTitle}" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="{i18n>main.menuTooltip}" accessibleName="{i18n>main.menuAccessible}" press=".onBurgerPress" class="headerBurgerButton"/>
                    <Button text="{i18n>main.aboutButton}" tooltip="{i18n>main.aboutTooltip}" accessibleName="{i18n>main.aboutAccessible}" press=".onNavToProject" class="headerDesktopActions"/>
                    <Button id="prozesseButton" text="{i18n>main.processButton}" tooltip="{i18n>main.processTooltip}" accessibleName="{i18n>main.processAccessible}" press=".onProzessePress" class="headerDesktopActions"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <MessageStrip
                id="btpHealthStrip"
                visible="{btpHealth>/visible}"
                text="{i18n>main.btpHealthOffline}"
                type="Warning"
                showIcon="true"
                showCloseButton="true"
                close=".onBtpHealthStripClose"
                link="{i18n>main.btpHealthLink}"
                linkPress=".onBtpHealthLinkPress"
                class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop"/>
            <cssgrid:CSSGrid
                id="processTilesGrid"
                gridTemplateColumns="1fr 1fr 1fr 1fr 1fr 1fr"
                gridGap="2rem"
                gridTemplateRows="auto auto"
                class="processTilesGrid">
                <!-- Zeile 1: 3 Kacheln (je 1/3) - RtR, R2R, S2P -->
                <!-- Recruit to Retire Tile -->
                <GenericTile
                    id="tileRtR"
                    header="Recruit to Retire"
                    subheader="Rekrutierung bis Ruhestand"
                    tooltip="Recruit to Retire: Detailseite öffnen"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartRtR"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/RtrHeadcountFunnel}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Record to Report Tile -->
                <GenericTile
                    id="tileR2R"
                    header="Record to Report"
                    subheader="Buchung bis Abschluss"
                    tooltip="Record to Report: Detailseite öffnen"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartR2R"
                                    vizType="pie"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: {
                                            dataLabel: { visible: true, type: 'value' },
                                            colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E','#F58B00'],
                                            margin: { top: 8, right: 8, bottom: 4, left: 8 }
                                        },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/R2RByAccountType}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Kontenklasse" value="{sales>type}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Anteil %" value="{sales>share}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="size" type="Measure" values="Anteil %"/>
                                        <viz.feeds:FeedItem uid="color" type="Dimension" values="Kontenklasse"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Source to Pay Tile -->
                <GenericTile
                    id="tileS2P"
                    header="Source to Pay"
                    subheader="Bestelleingang pro Monat"
                    tooltip="Source to Pay: Bestellungen je Monat · Detailseite öffnen"
                    class="processTile tileThird"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartS2P"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: {
                                            dataLabel: { visible: true, type: 'value' },
                                            colorPalette: ['#0070F2'],
                                            margin: { top: 12, right: 8, bottom: 4, left: 44 }
                                        },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/S2POrdersByMonth}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Bestellungen" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Bestellungen"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Zeile 2: 2 Kacheln (je 50%) - D2O, L2C -->
                <!-- Design to Operate Tile -->
                <GenericTile
                    id="tileD2O"
                    header="Design to Operate"
                    subheader="Design bis Betrieb"
                    tooltip="Design to Operate: Detailseite öffnen"
                    class="processTile tileHalf"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartD2O"
                                    vizType="line"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#107E3E'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/D2OOutputTrend}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Output" value="{sales>output}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Output"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <!-- Lead to Cash Tile -->
                <GenericTile
                    id="tileL2C"
                    header="Lead to Cash"
                    subheader="Lead bis Zahlungseingang"
                    tooltip="Lead to Cash: Detailseite öffnen"
                    class="processTile tileHalf"
                    press=".onTilePress">
                    <tileContent>
                        <TileContent>
                            <content>
                                <viz:VizFrame
                                    id="tileChartL2C"
                                    vizType="column"
                                    height="100%"
                                    width="100%"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2'], margin: { top: 12, right: 8, bottom: 4, left: 44 } },
                                        categoryAxis: { title: { visible: false } },
                                        valueAxis: { title: { visible: false } },
                                        legend: { visible: true, isScrollable: true },
                                        legendGroup: { layout: { position: 'bottom', alignment: 'left' } }
                                    }">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{sales>/L2CConversionFunnel}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
            </cssgrid:CSSGrid>
        </content>
    </Page>
</mvc:View>
