<mvc:View
    controllerName="ui5.vizframe.app.controller.Project"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true">
    <Page id="projectPage" title="Über dieses Projekt" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" tooltip="Zurück" accessibleName="Zurück zur Startseite" press=".onNavBack"/>
                    <Title text="Über dieses Projekt" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="Menü" accessibleName="Hauptmenü öffnen" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="sapUiSmallMargin">
                <l:VerticalLayout width="100%">
                    <Title text="KPI Dashboard – Geschäftsprozesse" level="H3"/>
                    <Text text="SAPUI5-Dashboard mit fünf End-to-End-Prozessen, KPI-Tabellen und VizFrame-Diagrammen. Ein KI-Assistent erklärt Prozesse, beantwortet Fragen zu Kennzahlen und navigiert bei Bedarf durch die App."
                        class="sapUiSmallMarginBottom"/>

                    <Title text="Hosting" level="H4" class="sapUiSmallMarginTop"/>
                    <List class="sapUiSmallMarginBottom">
                        <StandardListItem title="Lokal (npm run start)" info="SAP-Sandbox-Daten + KI-Assistent (Groq) – volle Funktion"/>
                        <StandardListItem title="GitHub Pages" info="Öffentliche Demo – Mock-Daten, Offline-Chat"/>
                        <StandardListItem title="SAP BTP" info="Geplant – Live-Daten und KI über geschütztes Backend"/>
                    </List>
                    <Link text="Repository auf GitHub" href="https://github.com/Malik-1909/UI5-Dashboard" target="_blank" class="sapUiSmallMarginBottom"/>

                    <Title text="Die fünf Geschäftsprozesse" level="H3" class="sapUiSmallMarginTop"/>
                    <Table id="processOverviewTable" class="sapUiSmallMarginBottom">
                        <columns>
                            <Column width="22%"><Text text="Prozess"/></Column>
                            <Column width="78%"><Text text="Kurzbeschreibung"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="Recruit to Retire" fontWeight="Bold"/>
                                    <Text text="Rekrutierung bis Ruhestand – gesamter Mitarbeiterlebenszyklus."/>
                                </cells>
                            </ColumnListItem>
                            <ColumnListItem>
                                <cells>
                                    <Text text="Record to Report" fontWeight="Bold"/>
                                    <Text text="Buchung bis Abschluss – Finanz- und Rechnungswesen."/>
                                </cells>
                            </ColumnListItem>
                            <ColumnListItem>
                                <cells>
                                    <Text text="Source to Pay" fontWeight="Bold"/>
                                    <Text text="Beschaffung bis Zahlung – Einkauf und Lieferantenmanagement."/>
                                </cells>
                            </ColumnListItem>
                            <ColumnListItem>
                                <cells>
                                    <Text text="Design to Operate" fontWeight="Bold"/>
                                    <Text text="Design bis Betrieb – hier u. a. Warenbewegungen und Lagerbestände aus der Sandbox."/>
                                </cells>
                            </ColumnListItem>
                            <ColumnListItem>
                                <cells>
                                    <Text text="Lead to Cash" fontWeight="Bold"/>
                                    <Text text="Lead bis Zahlungseingang – Vertrieb und Forderungsmanagement."/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <Title text="Prozessschritte" level="H3" class="sapUiSmallMarginTop"/>
                    <Text text="Phasenüberblick je End-to-End-Prozess. Detailseiten fokussieren auf KPIs und Diagramme."
                        class="sapUiSmallMarginBottom"/>

                    <Panel expandable="true" expanded="false" width="100%" class="sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Lead to Cash" level="H5"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List>
                                <StandardListItem title="Lead" info="Interessent erfassen und qualifizieren"/>
                                <StandardListItem title="Opportunity" info="Geschäftsmöglichkeit bewerten"/>
                                <StandardListItem title="Quote" info="Angebot erstellen und versenden"/>
                                <StandardListItem title="Order" info="Auftrag erfassen und freigeben"/>
                                <StandardListItem title="Delivery" info="Lieferung und Übergabe"/>
                                <StandardListItem title="Invoice" info="Rechnungsstellung"/>
                                <StandardListItem title="Collection" info="Zahlungseingang"/>
                            </List>
                        </content>
                    </Panel>
                    <Panel expandable="true" expanded="false" width="100%" class="sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Source to Pay" level="H5"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List>
                                <StandardListItem title="Bedarfsmeldung" info="Bedarf anfordern und freigeben"/>
                                <StandardListItem title="Bestellung" info="Bestellung auslösen"/>
                                <StandardListItem title="Wareneingang" info="Wareneingang und Prüfung"/>
                                <StandardListItem title="Rechnungsprüfung" info="Dreiseitenabgleich"/>
                                <StandardListItem title="Zahlung" info="Zahlung an Lieferant"/>
                            </List>
                        </content>
                    </Panel>
                    <Panel expandable="true" expanded="false" width="100%" class="sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Record to Report" level="H5"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List>
                                <StandardListItem title="Buchung" info="Transaktionserfassung"/>
                                <StandardListItem title="Kontenabstimmung" info="Bank- und Sachkonten"/>
                                <StandardListItem title="Periodenabschluss" info="Monats- und Jahresabschluss"/>
                                <StandardListItem title="Konsolidierung" info="Konzernabschluss"/>
                                <StandardListItem title="Reporting" info="Finanzberichte"/>
                            </List>
                        </content>
                    </Panel>
                    <Panel expandable="true" expanded="false" width="100%" class="sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Recruit to Retire" level="H5"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List>
                                <StandardListItem title="Recruiting" info="Stellenausschreibung"/>
                                <StandardListItem title="Onboarding" info="Einarbeitung"/>
                                <StandardListItem title="Performance" info="Leistungsbeurteilung"/>
                                <StandardListItem title="Development" info="Weiterbildung"/>
                                <StandardListItem title="Compensation" info="Vergütung"/>
                                <StandardListItem title="Offboarding" info="Austritt"/>
                            </List>
                        </content>
                    </Panel>
                    <Panel expandable="true" expanded="false" width="100%" class="sapUiSmallMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar style="Clear">
                                <Title text="Design to Operate" level="H5"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <List>
                                <StandardListItem title="Design" info="Produktdesign"/>
                                <StandardListItem title="Engineering" info="Konstruktion"/>
                                <StandardListItem title="Procure" info="Beschaffung"/>
                                <StandardListItem title="Manufacture" info="Fertigung"/>
                                <StandardListItem title="Deploy" info="Auslieferung"/>
                                <StandardListItem title="Operate" info="Betrieb"/>
                                <StandardListItem title="Service" info="Support"/>
                            </List>
                        </content>
                    </Panel>

                    <Title text="Technologie" level="H3" class="sapUiSmallMarginTop"/>
                    <List class="sapUiSmallMarginBottom">
                        <StandardListItem title="SAPUI5 1.120" info="XML-Views, Horizon Theme"/>
                        <StandardListItem title="sap.viz" info="VizFrame-Diagramme"/>
                        <StandardListItem title="JSONModel sales" info="Mock-Bundle + optional SAP-Sandbox-Merge"/>
                        <StandardListItem title="KI-Assistent" info="Groq lokal · Offline-Regeln auf GitHub Pages"/>
                    </List>

                    <Title text="Funktionen" level="H3" class="sapUiSmallMarginTop"/>
                    <List>
                        <StandardListItem title="Startseite" info="Fünf Prozesskacheln mit Mini-Charts"/>
                        <StandardListItem title="Detailseiten" info="KPI-Tabelle, Diagramme, Datenquellen-Badge"/>
                        <StandardListItem title="Navigation" info="Kacheln, Menü, KI-Button, Zurück"/>
                        <StandardListItem title="Responsives Layout" info="Desktop → Tablet → Mobile"/>
                    </List>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
