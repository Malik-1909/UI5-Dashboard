<mvc:View
    controllerName="ui5.vizframe.app.controller.Project"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true">
    <Page id="projectPage" title="{i18n>project.pageTitle}" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" tooltip="{i18n>project.backTooltip}" accessibleName="{i18n>project.backAccessible}" press=".onNavBack"/>
                    <Title text="{i18n>project.headerTitle}" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="{i18n>project.menuTooltip}" accessibleName="{i18n>project.menuAccessible}" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="projectScroll">
                <l:VerticalLayout width="100%">

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.title}" level="H3"/>
                        <Text text="{i18n>project.intro1}" class="projectProse sapUiTinyMarginTop"/>
                    </l:VerticalLayout>

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.whatTitle}" level="H4"/>
                        <Text text="{i18n>project.whatBody}" class="projectProse sapUiTinyMarginTop"/>
                    </l:VerticalLayout>

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.processesTitle}" level="H3"/>
                        <Text text="{i18n>project.processesIntro}" class="projectProse sapUiTinyMarginTop"/>
                        <Panel headerText="{i18n>process.rtr}" expandable="true" expanded="false" class="projectProcessPanel sapUiTinyMarginTop">
                            <content>
                                <Text text="{i18n>project.rtrNarrative}" class="projectProse projectProseInPanel"/>
                            </content>
                        </Panel>
                        <Panel headerText="{i18n>process.r2r}" expandable="true" expanded="false" class="projectProcessPanel">
                            <content>
                                <Text text="{i18n>project.r2rNarrative}" class="projectProse projectProseInPanel"/>
                            </content>
                        </Panel>
                        <Panel headerText="{i18n>process.s2p}" expandable="true" expanded="false" class="projectProcessPanel">
                            <content>
                                <Text text="{i18n>project.s2pNarrative}" class="projectProse projectProseInPanel"/>
                            </content>
                        </Panel>
                        <Panel headerText="{i18n>process.d2o}" expandable="true" expanded="false" class="projectProcessPanel">
                            <content>
                                <Text text="{i18n>project.d2oNarrative}" class="projectProse projectProseInPanel"/>
                            </content>
                        </Panel>
                        <Panel headerText="{i18n>process.l2c}" expandable="true" expanded="false" class="projectProcessPanel">
                            <content>
                                <Text text="{i18n>project.l2cNarrative}" class="projectProse projectProseInPanel"/>
                            </content>
                        </Panel>
                    </l:VerticalLayout>

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.hostingTitle}" level="H3"/>
                        <Text text="{i18n>project.hostingBody}" class="projectProse sapUiTinyMarginTop"/>
                        <Title text="{i18n>project.sapProxyTitle}" level="H4" class="sapUiSmallMarginTop"/>
                        <Text text="{i18n>project.sapProxyBody}" class="projectProse sapUiTinyMarginTop"/>
                        <Text text="{i18n>project.keepaliveBody}" class="projectProse sapUiTinyMarginTop"/>
                    </l:VerticalLayout>

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.techTitle}" level="H3"/>
                        <Text text="{i18n>project.techBody1}" class="projectProse sapUiTinyMarginTop"/>
                        <Text text="{i18n>project.techBody2}" class="projectProse sapUiTinyMarginTop"/>
                    </l:VerticalLayout>

                    <l:VerticalLayout width="100%" class="sapUiMediumMarginBottom">
                        <Title text="{i18n>project.featuresTitle}" level="H3"/>
                        <Text text="{i18n>project.featuresBody}" class="projectProse sapUiTinyMarginTop"/>
                    </l:VerticalLayout>

                    <Link text="{i18n>project.repoLinkText}" href="https://github.com/Malik-1909/UI5-Dashboard" target="_blank"/>

                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
