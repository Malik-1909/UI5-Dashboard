<mvc:View
    controllerName="ui5.vizframe.app.controller.RtR"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="rtrPage" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" press=".onNavBack"/>
                    <Title text="Recruit to Retire" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <Button id="burgerButton" icon="sap-icon://menu2" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="sapUiSmallMargin">
                <l:VerticalLayout width="100%">
                    <Title text="Recruit to Retire Prozess" level="H3"/>
                    <Text text="Recruit to Retire (RtR) umfasst den gesamten Mitarbeiterlebenszyklus von der Rekrutierung bis zum Ruhestand. Der Prozess verbindet Personalbeschaffung, Entwicklung und Offboarding."
                        class="sapUiSmallMarginBottom"/>
                    <Title text="Prozessschritte" level="H4"/>
                    <List>
                        <StandardListItem title="1. Recruiting" info="Stellenausschreibung und Kandidatensuche"/>
                        <StandardListItem title="2. Onboarding" info="Einarbeitung und Integration neuer Mitarbeiter"/>
                        <StandardListItem title="3. Performance" info="Leistungsbeurteilung und Zielvereinbarung"/>
                        <StandardListItem title="4. Development" info="Weiterbildung und Karriereentwicklung"/>
                        <StandardListItem title="5. Compensation" info="Vergütung und Benefits"/>
                        <StandardListItem title="6. Offboarding" info="Austritt und Wissenstransfer"/>
                    </List>
                    <Title text="KPI-Übersicht" level="H4" class="sapUiSmallMarginTop"/>
                    <Table id="rtrKpiTable" items="{sales>/rtrKpiTable}" class="sapUiSmallMarginBottom">
                        <columns>
                            <Column width="50%"><Text text="KPI"/></Column>
                            <Column><Text text="Wert"/></Column>
                            <Column><Text text="Einheit"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{sales>kpi}"/>
                                    <Text text="{sales>value}"/>
                                    <Text text="{sales>unit}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                    <Title text="Wichtige Diagramme für RtR" level="H3" class="sapUiSmallMarginTop"/>
                    <Text text="Die folgenden Diagramme unterstützen die Steuerung des HR-Prozesses: Headcount-Funnel, Verteilung nach Abteilung und Fluktuationstrend."
                        class="sapUiSmallMarginBottom"/>
                    <Panel headerText="1. Headcount-Funnel" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
                        <content>
                            <Text text="Zeigt die Anzahl Mitarbeiter pro Prozessstufe. Wichtig zur Identifikation von Engpässen im Recruiting und Onboarding."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="rtrFunnelChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Mitarbeiter pro Stufe' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/rtrHeadcountFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="2. Headcount nach Abteilung" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
                        <content>
                            <Text text="Zeigt die Verteilung der Mitarbeiter auf Abteilungen. Wichtig für die Ressourcenplanung und Schwerpunktanalyse."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="rtrDepartmentChart"
                                vizType="donut"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Mitarbeiter nach Abteilung' },
                                    plotArea: { dataLabel: { visible: true, type: 'percentage' }, colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E','#F58B00'] },
                                    legend: { visible: true }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/rtrByDepartment}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Abteilung" value="{sales>department}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>headcount}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Abteilung"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="3. Fluktuationstrend (%)" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
                        <content>
                            <Text text="Zeigt die monatliche Fluktuationsrate. Wichtig für die Mitarbeiterbindung und Retention-Strategien."
                                class="sapUiSmallMarginBottom"/>
                            <viz:VizFrame
                                id="rtrAttritionChart"
                                vizType="line"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Fluktuation (%)' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#107E3E'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/rtrAttritionTrend}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Rate" value="{sales>rate}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Rate"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Title text="Zusammenfassung" level="H4"/>
                    <Text text="Für RtR sind Säulendiagramme (Headcount-Funnel), Donut-Diagramme (Abteilungsverteilung) und Liniendiagramme (Fluktuationstrend) relevant."
                        class="sapUiSmallMarginBottom"/>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
