<mvc:View
    controllerName="ui5.vizframe.app.controller.RtR"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="rtrPage" title="Recruit to Retire" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" tooltip="Zurück" accessibleName="Zurück zur Startseite" press=".onNavBack"/>
                    <Title text="Recruit to Retire" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="Menü" accessibleName="Hauptmenü öffnen" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <MessageStrip
                        text="{sales>/_sapBadgeRtR}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeRtR}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="Demo-Daten (Mock) · SAP API nicht konfiguriert oder nicht erreichbar"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeRtR}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="KPI-Übersicht" level="H4"/>
                            <Table id="rtrKpiTable" items="{sales>/RtrKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="KPI"/></Column>
                                    <Column><Text text="Wert"/></Column>
                                    <Column><Text text="Einheit"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="Diagramme" level="H3" class="sapUiSmallMarginTop"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. Headcount-Funnel' + (${sales>/_sapBadgeRtR} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="rtrFunnelChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Mitarbeiter pro Stufe' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/RtrHeadcountFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Headcount nach Abteilung' + (${sales>/_sapBadgeRtR} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="rtrDepartmentChart"
                                vizType="donut"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Mitarbeiter nach Abteilung' },
                                    plotArea: { dataLabel: { visible: true, type: 'percentage' }, colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E','#F58B00'] },
                                    legend: { visible: true }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/RtrByDepartment}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Abteilung" value="{sales>department}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>headcount}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Abteilung"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Top Job-Titel' + (${sales>/_sapBadgeRtR} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <viz:VizFrame
                                id="rtrJobTitleChart"
                                vizType="bar"
                                height="300px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Top Job-Titel (Anzahl Mitarbeiter)' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/RtrByJobTitle}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Titel" value="{sales>title}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Titel"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
