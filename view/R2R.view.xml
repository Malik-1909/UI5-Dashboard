<mvc:View
    controllerName="ui5.vizframe.app.controller.R2R"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="r2rPage" title="Record to Report" enableScrolling="true" showHeader="true">
        <customHeader>
            <core:Fragment fragmentName="ui5.vizframe.app.fragment.ProcessDetailHeader" type="XML"/>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <MessageStrip
                        text="{sales>/_sapBadgeR2R}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeR2R}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="Demo-Daten (Mock) · SAP API nicht konfiguriert oder nicht erreichbar"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeR2R}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="KPI-Übersicht" level="H4"/>
                            <Table id="r2rKpiTable" items="{sales>/R2RKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="KPI"/></Column>
                                    <Column><Text text="Wert"/></Column>
                                    <Column><Text text="Einheit"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="Diagramme" level="H3" class="sapUiSmallMarginTop"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. Buchungen nach Kontenklasse' + (${sales>/_sapBadgeR2R} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="r2rFunnelChart"
                                vizType="pie"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Buchungsverteilung nach Kontenklasse (%)' },
                                    plotArea: { dataLabel: { visible: true, type: 'percentage' }, colorPalette: ['#0070F2','#1B90FF','#5AAAFF','#107E3E','#F58B00'] },
                                    legend: { visible: true }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/R2RByAccountType}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Kontenklasse" value="{sales>type}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anteil" value="{sales>share}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Anteil"/>
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Kontenklasse"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Buchungen pro Periode' + (${sales>/_sapBadgeR2R} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="r2rEntriesChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Buchungen pro Periode' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/R2RJournalEntries}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Periode" value="{sales>period}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Buchungen" value="{sales>entries}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Buchungen"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Periode"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Soll-/Haben-Verteilung' + (${sales>/_sapBadgeR2R} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <viz:VizFrame
                                id="r2rDebitCreditChart"
                                vizType="donut"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Soll (S) vs. Haben (H) – Anzahl Buchungen' },
                                    plotArea: { dataLabel: { visible: true, type: 'percentage' }, colorPalette: ['#0070F2','#107E3E'] },
                                    legend: { visible: true }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/R2RDebitCreditSplit}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Buchungsart" value="{sales>type}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Buchungsart"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
