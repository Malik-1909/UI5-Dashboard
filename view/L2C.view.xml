<mvc:View
    controllerName="ui5.vizframe.app.controller.L2C"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">
    <Page id="l2cPage" title="Lead to Cash" enableScrolling="true" showHeader="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" tooltip="Zurück" accessibleName="Zurück zur Startseite" press=".onNavBack"/>
                    <Title text="Lead to Cash" level="H2"/>
                </contentLeft>
                <contentMiddle/>
                <contentRight>
                    <core:Fragment fragmentName="ui5.vizframe.app.fragment.HeaderKiButton" type="XML"/>
                    <Button id="burgerButton" icon="sap-icon://menu2" tooltip="Menü" accessibleName="Hauptmenü öffnen" press=".onBurgerPress" class="headerBurgerButton"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <ScrollContainer height="100%" vertical="true" class="processDetailScroll">
                <l:VerticalLayout width="100%" class="processDetailMain">
                    <MessageStrip
                        text="{sales>/_sapBadgeL2C}"
                        type="Information"
                        showCloseButton="false"
                        visible="{= !!${sales>/_sapBadgeL2C}}"
                        class="sapUiSmallMarginBottom"/>
                    <MessageStrip
                        text="Demo-Daten (Mock) · SAP API nicht konfiguriert oder nicht erreichbar"
                        type="Warning"
                        showCloseButton="false"
                        visible="{= !${sales>/_sapBadgeL2C}}"
                        class="sapUiSmallMarginBottom"/>
                    <VBox width="100%" class="processDetailKpiBlock">
                            <Title text="KPI-Übersicht" level="H4"/>
                            <Table id="l2cKpiTable" items="{sales>/L2CKpiTable}" class="processDetailKpiTable">
                                <columns>
                                    <Column width="50%"><Text text="KPI"/></Column>
                                    <Column><Text text="Wert"/></Column>
                                    <Column><Text text="Einheit"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{sales>kpi}"/>
                                            <Text text="{sales>value}"/>
                                            <Text text="{sales>unit}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                    </VBox>
                    <Title text="Diagramme" level="H3" class="sapUiSmallMarginTop"/>
                    <cssgrid:CSSGrid
                        class="processDetailChartsGrid"
                        width="100%"
                        gridTemplateColumns="minmax(0, 1fr) minmax(0, 1fr)"
                        gridGap="1rem 1.5rem">
                    <Panel headerText="{= '1. L2C-Conversion-Funnel' + (${sales>/_sapBadgeL2C} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="l2cFunnelChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Pipeline pro Prozessstufe' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#0070F2'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/L2CConversionFunnel}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Anzahl" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Anzahl"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    <Panel headerText="{= '2. Umsatz pro Prozessstufe (Ist vs. Ziel)' + (${sales>/_sapBadgeL2C} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel">
                        <content>
                            <viz:VizFrame
                                id="l2cRevenueChart"
                                vizType="bar"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Umsatz (T EUR) pro Stufe' },
                                    plotArea: { dataLabel: { visible: false }, colorPalette: ['#0070F2','#F58B00'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/L2CRevenueByStage}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Stufe" value="{sales>stage}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Umsatz" value="{sales>revenue}"/>
                                            <viz.data:MeasureDefinition name="Ziel" value="{sales>target}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Umsatz,Ziel"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stufe"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                    </cssgrid:CSSGrid>
                    <Panel headerText="{= '3. Auftragseingang pro Monat' + (${sales>/_sapBadgeL2C} ? ' · SAP API' : ' · Mock')}" expandable="true" expanded="true" class="processDetailChartPanel processDetailChartPanelFull sapUiSmallMarginTop">
                        <content>
                            <viz:VizFrame
                                id="l2cOrdersTrendChart"
                                vizType="column"
                                height="280px"
                                width="100%"
                                uiConfig="{applicationSet:'fiori'}"
                                vizProperties="{
                                    title: { text: 'Auftragseingang pro Monat' },
                                    plotArea: { dataLabel: { visible: true }, colorPalette: ['#107E3E'] },
                                    categoryAxis: { title: { visible: false } },
                                    valueAxis: { title: { visible: false } }
                                }">
                                <viz:dataset>
                                    <viz.data:FlattenedDataset data="{sales>/L2COrdersByMonth}">
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition name="Monat" value="{sales>month}"/>
                                        </viz.data:dimensions>
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition name="Aufträge" value="{sales>count}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Aufträge"/>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Monat"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </content>
                    </Panel>
                </l:VerticalLayout>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
