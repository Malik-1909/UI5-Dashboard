# Kopiere diese Datei als ".env" und trage deinen Groq API Key ein.
# Kostenloser Key (kein Kreditkarte): https://console.groq.com -> "Create API Key"
#
# WICHTIG: Die .env Datei ist in .gitignore – sie wird NIE committed.

GROQ_API_KEY=gsk_...deinen_key_hier_eintragen

# SAP Business Accelerator Hub API Key (https://api.sap.com -> Settings -> Show API Key)
SAP_API_KEY=dein_sap_api_key_hier

# Optional: Demo-Modus ohne API (Standard wenn kein Key gesetzt)
# MOCK_MODE=true

# Referral-Tracking (POST /api/track). Optional lokal – ohne diese Keys landen
# die Events nur in logs/visits.jsonl. Auf BTP per `cf set-env` setzen.
# service_role-Key ist geheim: nur serverseitig, NIE ins Frontend/Git.
# SUPABASE_URL=https://dein-projekt.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=dein_service_role_key
# SUPABASE_VISITS_TABLE=visits
